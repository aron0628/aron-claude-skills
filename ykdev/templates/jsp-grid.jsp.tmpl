<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/jsp/common/auiHeader.jsp" %>
<!-- ${description} -->
<div class="content-body">

	<!-- 검색 영역 -->
	<div class="search-wrap">
		<div class="search-inner">
			<table class="search-tbl">
				<colgroup>
					<col width="80px">
					<col width="">
					<col width="80px">
					<col width="">
				</colgroup>
				<tr>
					<!-- TODO: 검색 조건 추가 -->
					<th>검색조건</th>
					<td>
						<input type="text" name="s_keyword" class="input-text" />
					</td>
					<th>기간</th>
					<td>
						<input type="text" name="s_start_dt" class="datepicker input-text width-100" />
						~
						<input type="text" name="s_end_dt" class="datepicker input-text width-100" />
					</td>
				</tr>
			</table>
		</div>
	</div>

	<!-- 그리드 영역 -->
	<div class="grid-wrap">
		<div class="grid-header">
			<span class="grid-title"><!-- TODO: 그리드 제목 --></span>
			<span class="grid-count">총 <strong id="totalCnt">0</strong>건</span>
		</div>
		<div id="auiGrid" style="width:100%;"></div>
	</div>

</div>

<script type="text/javascript">
(function () {

	// ========== 그리드 설정 ==========
	var myGrid;

	var columnLayout = [
		// TODO: 컬럼 레이아웃 정의
		// { dataField: "column_name", headerText: "컬럼명", width: 120 },
		// { dataField: "amount", headerText: "금액", width: 100, dataType: "numeric", formatString: "#,##0" },
		// { dataField: "date_field", headerText: "일자", width: 100, dataType: "date", formatString: "yyyy-mm-dd" },
	];

	var gridProps = {
		headerHeight: 30,
		rowHeight: 28,
		showRowNumColumn: true,
		showRowCheckColumn: false,   // TODO: 체크박스 필요 시 true
		editable: false,             // TODO: 편집 필요 시 true
		selectionMode: "singleRow",
		noDataMessage: "데이터가 없습니다.",
		// showFooter: false,        // TODO: 합계 필요 시 true
	};

	function createAUIGrid() {
		myGrid = AUIGrid.create("#auiGrid", columnLayout, gridProps);

		// TODO: 이벤트 바인딩
		// AUIGrid.bind(myGrid, "cellClick", function (event) { });
		// AUIGrid.bind(myGrid, "cellEditEnd", function (event) { });
	}

	// ========== 조회 ==========
	function goSearch() {
		$M.goNextPageAjax("/${domain_lower}/${domain_lower}${menu}/search", function (data) {
			AUIGrid.setGridData(myGrid, data.list);
			$M.setValue("totalCnt", data.total_cnt);
		});
	}

	// ========== 저장 ==========
	// function goSave() {
	//     $M.goNextPageAjaxPost("/${domain_lower}/${domain_lower}${menu}/save", function (data) {
	//         $M.alertMsg("저장되었습니다.");
	//         goSearch();
	//     });
	// }

	// ========== 팝업 호출 ==========
	// function openPopup(param) {
	//     var option = { width: 800, height: 600 };
	//     $M.openWindow("/${domain_lower}/${domain_lower}${menu}p01", param, option);
	// }

	// ========== 초기화 ==========
	$(function () {
		createAUIGrid();
		goSearch();
	});

	// ========== 외부 함수 ==========
	// 팝업 콜백 등 외부에서 호출해야 하는 함수
	// window.callbackPopup = function (data) { goSearch(); };

})();
</script>

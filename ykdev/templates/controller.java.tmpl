package sunnyyk.erp.web.controller.${domain_lower};

import mobile.factory.RequestDataSet;
import mobile.factory.util.ResponseUtil;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import org.springframework.web.servlet.ModelAndView;
import sunnyyk.erp.common.service.web.${domain_lower}.${DOMAIN}${MENU}Service;
import sunnyyk.erp.web.core.spring.DefaultController;

import java.util.List;
import java.util.Map;

/**
 * <pre>
 * ${description}
 * </pre>
 *
 * @author ${author}
 * @date ${date}
 */
@Controller(value = "${domain_lower}${menu}Controller")
@RequestMapping(value = "/${domain_lower}")
public class ${DOMAIN}${MENU}Controller extends DefaultController {
	private final Logger logger = LoggerFactory.getLogger(this.getClass());

	@Autowired
	${DOMAIN}${MENU}Service ${domain_lower}${menu}Service;

	/**
	 * 페이지 이동
	 */
	@RequestMapping(value = "/${domain_lower}${menu}", method = RequestMethod.GET)
	public ModelAndView staticPage(RequestDataSet dataSet) throws Exception {
		ModelAndView mav = new ModelAndView("/${domain_lower}/${domain_lower}${menu}");
		setPageBtnAuth(dataSet, mav);
		return mav;
	}

	/**
	 * 목록 조회
	 */
	@RequestMapping(value = "/${domain_lower}${menu}/search", method = RequestMethod.GET)
	public ModelAndView search(RequestDataSet dataSet) throws Exception {
		String[] notBlankField = new String[] {};
		dataSet.requiredFieldCheck(notBlankField);

		List<Map<String, Object>> list = ${domain_lower}${menu}Service.selectList(dataSet.inGetMap());

		return dataSet.resultToJSON(ResponseUtil.successResult(list));
	}
} //:)--

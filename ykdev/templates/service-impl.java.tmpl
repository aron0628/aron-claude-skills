	/**
	 * 저장 (등록/수정/삭제 — cmd 기반 분기)
	 */
	@Override
	public void save(Map<String, String> param) {
		String cmd = param.get("cmd");

		if ("I".equals(cmd)) {
			insert(param);
		} else if ("U".equals(cmd)) {
			update(param);
		} else if ("D".equals(cmd)) {
			delete(param);
		}
	}

